## Ignore Visual Studio temporary files, build results, and
## files generated by popular Visual Studio add-ons.

# User-specific files
*.rsuser
*.suo
*.user
*.userosscache
*.sln.docstates

# User-specific files (DotSettings)
*.ryouser

# Build results
[Dd]ebug/
[Dd]ebugPublic/
[Rr]elease/
[Rr]eleases/
x64/
x86/
[Aa][Rr][Mm]/
[Aa][Rr][Mm]64/
bld/
[Bb]in/
[Oo]bj/
[Ll]og/
[Vv]isual[Ss]tudio[Ee]xplorer/

# Visual Studio 2015/2017 cache/options directory
.vs/
# Uncomment if you use tasks that create to-do list files in the .vs directory
# .vs/todo.json
.librarymanager.json

# Visual Studio 2015/2017 build results directory
Artifacts/

# MSTest test Results
[Tt]est[Rr]esult*/
[Bb]uild[Ll]og.*

# NUnit
*.VisualState.xml
TestResult.xml

# Build log of MSBuild
*.log
*.tlog
*.lastbuildstate

# Entity Framework 6+ dự án
*.Migrations.cs

# NuGet Packages
*.nupkg
# The packages folder can be ignored because of Package Restore
**/[Pp]ackages/*
# except build/, which is used as an MSBuild target.
!**/[Pp]ackages/build/
# Uncomment if using NuGet repositories to store flags or packages.
# !**/[Pp]ackages/repository.config
# Project-specific metadata files
*.nuget.props
*.nuget.targets

# Microsoft Azure Build Output
csx/
*.jscfg
*.csdef
*.cscfg
*.pubxml
*.azurePubxml

# Others
sql/
*.bak
*.mdf
*.ldf
*.tmp
*.log
.DS_Store

# Docker
.dockerignore
